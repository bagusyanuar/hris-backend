meta {
  name: Get All Job Positions
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/organization/job-positions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Mengambil daftar semua slot posisi pekerjaan (job positions).
  
  Expected Responses:
  - 200 OK: Successfully retrieved all job positions
}

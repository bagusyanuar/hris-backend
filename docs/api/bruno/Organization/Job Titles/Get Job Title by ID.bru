meta {
  name: Get Job Title by ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/organization/job-titles/:id
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Mengambil detail jabatan (job title) berdasarkan ID.
  Required Properties:
  - id (path parameter)
  
  Expected Responses:
  - 200 OK: Successfully retrieved job title
  - 404 Not Found: Job title not found
}

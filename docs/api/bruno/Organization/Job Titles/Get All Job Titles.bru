meta {
  name: Get All Job Titles
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/organization/job-titles
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Mengambil daftar semua jabatan (job titles).
  
  Expected Responses:
  - 200 OK: Successfully retrieved all job titles
}

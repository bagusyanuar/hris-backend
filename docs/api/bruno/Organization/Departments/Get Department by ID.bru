meta {
  name: Get Department by ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/organization/departments/:id
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Mengambil detail departemen berdasarkan ID.
  Required Properties:
  - id (path parameter)
  
  Expected Responses:
  - 200 OK: Successfully retrieved department
  - 404 Not Found: Department not found
}

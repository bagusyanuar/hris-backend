APP_NAME="hris-backend"
APP_VERSION="1.0.0"

APP_ENV=development
APP_PORT=8000
APP_DEBUG=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hris_db
DB_SSLMODE=disable
DB_TZ=Asia/Jakarta

# Database connection pool & resiliency (opsional — kosongkan untuk pakai default di kode)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=5
DB_CONNECT_TIMEOUT_SECONDS=10
DB_CONNECT_RETRY_ATTEMPTS=5
DB_CONNECT_RETRY_DELAY_SECONDS=2
DB_SLOW_QUERY_THRESHOLD_MS=200

# JWT configuration
JWT_SECRET=yoursecretkeyhere
JWT_EXPIRY_HOUR=1
JWT_REFRESH_EXPIRY_HOUR=168